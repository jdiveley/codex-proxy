# Port the proxy listens on (Codex must point here)
PORT=8080

# Base URL of the backend API (e.g. Ask Sage, or direct provider)
# Ask Sage example: https://sage.ask-sage.ai
# Direct OpenAI:    https://api.openai.com
# Direct Anthropic: https://api.anthropic.com  (for ANTHROPIC_BASE_URL override)
BACKEND_BASE_URL=https://api.openai.com

# Authentication token sent as Bearer to the backend
# For Ask Sage: your personal user API token
# For OpenAI:   your OpenAI API key
API_TOKEN=your-token-here

# --- Optional per-provider base URL overrides ---
# Leave blank to derive from BACKEND_BASE_URL with the standard path prefixes.
# When set, these override the base for that specific provider's requests.
# e.g. ANTHROPIC_BASE_URL=https://sage.ask-sage.ai/server/anthropic
#      OPENAI_BASE_URL=https://sage.ask-sage.ai/server/openai
#      GEMINI_BASE_URL=https://sage.ask-sage.ai/server/google
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
GEMINI_BASE_URL=

# Maximum tokens to request when none specified (default: 8192)
DEFAULT_MAX_TOKENS=8192

# Session TTL in milliseconds for previous_response_id tracking (default: 1 hour)
SESSION_TTL_MS=3600000

# Set to "true" to enable verbose request/response logging
DEBUG=false

# Optional: path to client TLS cert/key for mutual TLS (DoD environments)
# CERT_PATH=/path/to/client.crt
# KEY_PATH=/path/to/client.key
# CA_PATH=/path/to/ca-bundle.crt
