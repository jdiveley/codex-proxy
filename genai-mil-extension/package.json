{
    "name": "genai-mil-connector",
    "displayName": "GenAI.mil Connector",
    "description": "Connect to GenAI.mil, Ask Sage, and Ask Sage Army (api.genai.army.mil) APIs from VS Code with interactive chat and file editing",
    "version": "9.4.4",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": ["Other"],
    "icon": "icon.png",
    "activationEvents": [
        "onCommand:genai-mil.openChat",
        "onCommand:genai-mil.setApiKey",
        "onCommand:genai-mil.deleteApiKey",
        "onCommand:genai-mil.selectEndpoint",
        "onCommand:genai-mil.selectModel",
        "onCommand:genai-mil.setAuthType",
        "onCommand:genai-mil.setPemCert",
        "onCommand:genai-mil.showSettings",
        "onCommand:genai-mil.fetchModels"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            { "command": "genai-mil.openChat",       "title": "GenAI.mil: Open Chat" },
            { "command": "genai-mil.setApiKey",      "title": "GenAI.mil: Set API Key" },
            { "command": "genai-mil.deleteApiKey",   "title": "GenAI.mil: Delete API Key" },
            { "command": "genai-mil.selectEndpoint", "title": "GenAI.mil: Select Endpoint" },
            { "command": "genai-mil.selectModel",    "title": "GenAI.mil: Select Model" },
            { "command": "genai-mil.setAuthType",    "title": "GenAI.mil: Set Auth Type" },
            { "command": "genai-mil.setPemCert",     "title": "GenAI.mil: Set PEM Certificate" },
            { "command": "genai-mil.showSettings",   "title": "GenAI.mil: Show Current Settings" },
            { "command": "genai-mil.fetchModels",    "title": "GenAI.mil: Fetch Available Models" }
        ],
        "menus": {
            "editor/title": [
                { "command": "genai-mil.openChat", "group": "navigation", "when": "true" }
            ],
            "editor/title/context": [
                { "command": "genai-mil.openChat", "group": "navigation" }
            ]
        },
        "configuration": {
            "title": "GenAI.mil",
            "properties": {
                "genai-mil.endpoint": {
                    "type": "string",
                    "default": "https://api.genai.army.mil/server/query",
                    "enum": [
                        "https://api.genai.army.mil/server/query",
                        "https://api.genai.mil/v1/chat/completions",
                        "https://api.asksage.ai/v1/chat/completions"
                    ],
                    "enumDescriptions": [
                        "Ask Sage Army - DoD Government (api.genai.army.mil) - Uses x-access-tokens header",
                        "GenAI.mil Chat Completions - OpenAI compatible streaming API",
                        "Ask Sage Chat Completions - OpenAI compatible streaming API"
                    ],
                    "description": "API Endpoint URL."
                },
                "genai-mil.model": {
                    "type": "string",
                    "default": "gpt-4.1-gov",
                    "description": "Model to use. Use 'Fetch Models' to get the latest list from the API."
                },
                "genai-mil.authType": {
                    "type": "string",
                    "default": "x-access-tokens",
                    "enum": ["bearer","api-key","x-api-key","x-access-tokens","anthropic-auth-token","basic"],
                    "enumDescriptions": [
                        "Authorization: Bearer YOUR_KEY",
                        "api-key: YOUR_KEY",
                        "x-api-key: YOUR_KEY",
                        "x-access-tokens: YOUR_KEY (Ask Sage Army native - use this)",
                        "ANTHROPIC_AUTH_TOKEN: YOUR_KEY (legacy)",
                        "Authorization: Basic YOUR_KEY"
                    ],
                    "description": "Authentication header type. Auto-set when selecting a known endpoint."
                },
                "genai-mil.pemPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to DoD PEM certificate. Leave empty to use NODE_EXTRA_CA_CERTS."
                },
                "genai-mil.temperature": {
                    "type": "number",
                    "default": 0.7,
                    "minimum": 0,
                    "maximum": 2,
                    "description": "Temperature (0=deterministic, 2=creative). Not used for Ask Sage Army endpoint."
                },
                "genai-mil.maxTokens": {
                    "type": "number",
                    "default": 4096,
                    "minimum": 1,
                    "maximum": 128000,
                    "description": "Max tokens in response. Not used for Ask Sage Army endpoint."
                }
            }
        }
    },
    "keywords": ["genai","army","mil","asksage","ask-sage","dod","government","ai","chat","gpt","gemini","claude","llm","copilot"],
    "license": "MIT"
}